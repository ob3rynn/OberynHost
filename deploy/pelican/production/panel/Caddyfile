# Sample output for panel.example.com and PANEL_HOST_PORT=8080.
# Prefer generating the real host config with:
#   ./bin/render-caddy-site.sh /etc/oberyn/pelican/panel.env
# That keeps the site host and reverse_proxy target aligned with panel.env.

panel.example.com {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    reverse_proxy 127.0.0.1:8080
}
