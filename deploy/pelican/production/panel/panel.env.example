PANEL_IMAGE=ghcr.io/oberyn/pelican-panel:manual-preci
PANEL_BASE_IMAGE=ghcr.io/pelican-dev/panel:v1.0.0-beta33
MARIADB_IMAGE=mariadb:11.4.5
REDIS_IMAGE=redis:7.4.2

PANEL_FQDN=panel.example.com
PANEL_HOST_PORT=8080

APP_NAME=OberynHost
APP_URL=https://panel.example.com
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_LOCALE=en
BEHIND_PROXY=true
TRUSTED_PROXIES=127.0.0.1

PANEL_RUNTIME_DIR=/srv/oberyn/pelican/runtime
PANEL_LOG_DIR=/srv/oberyn/pelican/logs/panel
PANEL_BACKUP_DIR=/srv/oberyn/pelican/backups
MARIADB_DATA_DIR=/srv/oberyn/pelican/mariadb

DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=panel
DB_USERNAME=pelican
DB_PASSWORD=CHANGE_ME
MARIADB_ROOT_PASSWORD=CHANGE_ME

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=null
REDIS_PASSWORD=null

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=support@example.com
MAIL_FROM_NAME=OberynHost
