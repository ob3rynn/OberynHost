# backend/.env is the source file for Docker Compose env_file injection.
# The backend server does not read this file directly at runtime.
#
# In the supported Docker workflow:
# - compose.yml pins HOST, PORT, and DATABASE_PATH per service
# - storefront-dev and storefront-stripe-dev also override BASE_URL/ALLOWED_ORIGINS
# - the placeholder values below are intentionally invalid and will fail startup/audits

# Optional bind settings for non-Docker starts only. Docker services ignore these.
PORT=3000
HOST=0.0.0.0

# Required public URL for the storefront runtime in this environment.
BASE_URL=https://storefront.example.com

# Optional comma-separated extra origins allowed for state-changing requests.
# Leave blank unless you intentionally serve the storefront through more than one origin.
ALLOWED_ORIGINS=

# Optional customer-facing hostname root. Server names are slugged under this
# domain during setup, for example my-server.oberyn.net.
CUSTOMER_HOSTNAME_ROOT_DOMAIN=oberyn.net

# Launch sender identity for queued customer emails.
OUTBOUND_EMAIL_FROM=support@oberynn.com

# Optional for non-Docker starts. Supported Docker services set this explicitly
# in compose.yml to a file path on a mounted volume, for example:
# DATABASE_PATH=/var/lib/oberynhost/storefront/storefront.sqlite3
# DATABASE_PATH=

# Required secrets and Stripe identifiers. Replace every placeholder before
# treating the storefront as runnable in any real environment.
ADMIN_KEY=replace-with-a-long-random-secret
# Optional dedicated key for encrypting staged setup secrets before the worker
# consumes them. If left blank, the runtime falls back to ADMIN_KEY.
SETUP_SECRET_KEY=
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_3GB=price_replace_me

# Optional phase-1 live Pelican provisioning. Leave blank until the panel URL,
# application API key, egg IDs, allocation IDs, and target resource limits are
# confirmed. If any of these are blank, the worker safely sends provisioning to
# admin review instead of calling Pelican.
PELICAN_PANEL_URL=
PELICAN_APPLICATION_API_KEY=
# Example shape:
# {"paper-launch-default":{"egg":{"byRuntimeProfile":{"paper-java17":1,"paper-java21":2,"paper-java25":3}},"allocationIds":[1001,1002],"dockerImage":{"byRuntimeProfile":{"paper-java17":"ghcr.io/pelican-eggs/yolks:java_17","paper-java21":"ghcr.io/pelican-eggs/yolks:java_21","paper-java25":"ghcr.io/pelican-eggs/yolks:java_25"}},"startup":"java -Xms128M -XX:MaxRAMPercentage=95.0 -jar {{SERVER_JARFILE}}","environment":{"SERVER_JARFILE":"server.jar","MINECRAFT_VERSION":"{{minecraftVersion}}","BUILD_NUMBER":"latest"},"limits":{"memory":3072,"swap":0,"disk":10240,"io":500,"cpu":0,"threads":null},"featureLimits":{"databases":0,"allocations":0,"backups":1},"skipScripts":false,"startOnCompletion":false,"oomKiller":true}}
PELICAN_PROVISIONING_TARGETS_JSON=
