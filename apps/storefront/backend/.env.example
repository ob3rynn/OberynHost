# Optional local bind settings. Keep HOST at 0.0.0.0 in containers.
PORT=3000
HOST=0.0.0.0

# Required public URL for the storefront runtime in this environment.
BASE_URL=https://storefront.example.com

# Optional comma-separated extra origins allowed for state-changing requests.
# Leave blank unless you intentionally serve the storefront through more than one origin.
ALLOWED_ORIGINS=

# Optional for local development. Containerized runtimes should set this explicitly
# to a file path on a mounted volume, for example:
# DATABASE_PATH=/var/lib/oberynhost/storefront/storefront.sqlite3
# DATABASE_PATH=

# Required secrets and Stripe identifiers.
ADMIN_KEY=replace-with-a-long-random-secret
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_2GB=price_replace_me
STRIPE_PRICE_4GB=price_replace_me
