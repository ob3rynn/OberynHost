# backend/.env is the source file for Docker Compose env_file injection.
# The backend server does not read this file directly at runtime.
#
# In the supported Docker workflow:
# - compose.yml pins HOST, PORT, and DATABASE_PATH per service
# - storefront-dev and storefront-stripe-dev also override BASE_URL/ALLOWED_ORIGINS
# - the placeholder values below are intentionally invalid and will fail startup/audits

# Optional bind settings for non-Docker starts only. Docker services ignore these.
PORT=3000
HOST=0.0.0.0

# Required public URL for the storefront runtime in this environment.
BASE_URL=https://storefront.example.com

# Optional comma-separated extra origins allowed for state-changing requests.
# Leave blank unless you intentionally serve the storefront through more than one origin.
ALLOWED_ORIGINS=

# Optional for non-Docker starts. Supported Docker services set this explicitly
# in compose.yml to a file path on a mounted volume, for example:
# DATABASE_PATH=/var/lib/oberynhost/storefront/storefront.sqlite3
# DATABASE_PATH=

# Required secrets and Stripe identifiers. Replace every placeholder before
# treating the storefront as runnable in any real environment.
ADMIN_KEY=replace-with-a-long-random-secret
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_3GB=price_replace_me
