# Dev-only live-ish fulfillment harness env.
# Copy values into your local harness environment after creating the Stripe and
# Pelican test resources described in docs/LIVEISH_FULFILLMENT_TEST_HARNESS.md.

PORT=3000
HOST=0.0.0.0
BASE_URL=http://127.0.0.1:3000
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DATABASE_PATH=

ADMIN_KEY=replace-with-a-long-random-secret
SETUP_SECRET_KEY=

# Stripe must be test mode for the harness.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_PAPER_2GB=price_replace_me

# The core harness uses local email logging. Postmark is optional and out of
# scope for the live-ish smoke.
OUTBOUND_EMAIL_FROM=support@oberynn.com
EMAIL_PROVIDER=log
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound

CUSTOMER_HOSTNAME_ROOT_DOMAIN=oberyn.net

# Pelican Application API. Used by the worker and by harness verification.
PELICAN_PANEL_URL=http://127.0.0.1:8080
PELICAN_APPLICATION_API_KEY=ptla_replace_me

# Reusable Pelican user used only for the second smoke scenario, where the
# harness proves customer-side Client API visibility for the provisioned server.
LIVEISH_HARNESS_PELICAN_USER_ID=
LIVEISH_HARNESS_PELICAN_USERNAME=
LIVEISH_HARNESS_PELICAN_CLIENT_API_KEY=ptlc_replace_me

# Optional extra validation for build-liveish-pelican-target.js.
LIVEISH_PELICAN_NODE_ID=
LIVEISH_PELICAN_NEST_ID=

# Generate and review this with:
# npm run build:liveish-target -- --target-json-file ./path/to/operator-target.json
#
# Required launch truth:
# - limits.memory must be 2424
# - startup or environment must carry the JVM target 2024
PELICAN_PROVISIONING_TARGETS_JSON=
